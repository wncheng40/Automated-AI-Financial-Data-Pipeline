    {
      "parameters": {
        "jsCode": "// 1. 獲取基礎資訊\nconst subject = $json.subject || \"\";\nconst from = $json.from?.value?.[0]?.address || $json.from || \"\";\n\n\n// 2. 選擇內容來源 (優先使用 html，因為它資訊最全)\nlet htmlContent = $json.html || \"\";\nlet textContent = $json.text || \"\";\n\n// 3. 處理 HTML：先將常見的「換行標籤」換成真正的換行，防止文字黏在一起\nlet processedHtml = htmlContent\n  .replace(/<style[^>]*>.*<\\/style>/gms, '') // 拔掉 CSS\n  .replace(/<br\\s*\\/?>/gi, '\\n')              // <br> 換行\n  .replace(/<\\/p>/gi, '\\n')                  // </p> 換行\n  .replace(/<\\/tr>/gi, '\\n')                 // 表格行結束換行\n  .replace(/<\\/div>/gi, '\\n')                // </div> 換行\n  .replace(/<[^>]*>?/gm, ' ')                // 拔掉剩下所有 HTML 標籤\n  .replace(/&nbsp;/g, ' ')                   // 處理空格轉義\n  .replace(/&amp;/g, '&')                    // 處理 & 符號\n  .replace(/&zwnj;/g, '') \n   // 🔥 在這裡新增：移除隱形字元\n  .replace(/\\n\\s*\\n/g, '\\n')                 // 移除連續空行\n  .trim();\n\n// 4. 聰明判斷：如果 HTML 清理出來沒東西，就用純文字版\nlet finalBody = processedHtml.length > 10 ? processedHtml : textContent;\n\n// 5. 組合最終包\nreturn {\n  emailContent: `\n【郵件來源】: ${from}\n【郵件主旨】: ${subject}\n【清理後的內文】:\n${finalBody.substring(0, 2000)}\n  `.trim()\n};"
      },
